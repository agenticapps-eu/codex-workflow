# install.sh in symlink mode creates ~/.codex/skills/setup-codex-agenticapps-workflow/templates
# which resolves through the main symlink back into the source repo. The
# secondary symlink is regenerated by install.sh; tracking it would cause
# spurious diffs. v0.2.0 follow-up: restructure so install.sh in symlink mode
# does not need to write inside the source tree.
skills/*/templates
